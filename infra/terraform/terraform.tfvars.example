aws_region         = "us-east-1"
instance_type      = "t3.micro"
key_pair_name      = "my-ec2-keypair"
allowed_cidrs      = ["0.0.0.0/0"]
host_port          = 42000
container_port     = 6000
docker_image_name  = "yourdockerhubuser/your-app"
docker_image_tag   = "latest"
instance_name      = "arem-docker-lab"
